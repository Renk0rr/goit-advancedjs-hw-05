{
  "compilerOptions": {
    "sourceMap": true,
    "target": "es2019",
    "module": "es2020",
    "lib": ["dom", "ES2021"],
    "rootDir": "./src",
    "outDir": "./dist",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true
  },
  "include": ["src/**/*.ts"]
}
